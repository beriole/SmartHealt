// SmartHealth Platform - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TypeUtilisateur {
  PATIENT
  MEDECIN
  PHARMACIEN
  INFIRMIER
  TUTEUR
  ADMIN
}

enum Sexe {
  M
  F
  AUTRE
}

enum Langue {
  fr
  en
}

enum StatutCompte {
  actif
  suspendu
  desactive
}

enum GroupeSanguin {
  A_PLUS
  A_MOINS
  B_PLUS
  B_MOINS
  AB_PLUS
  AB_MOINS
  O_PLUS
  O_MOINS
}

enum StatutVerification {
  en_attente
  verifie
  rejete
}

enum FormeGalenique {
  comprime
  sirop
  injection
  creme
  suppositoire
  pommade
}

enum CategorieMedicament {
  antibiotique
  antalgique
  antiparasitaire
  vaccin
  autre
}

enum StatutMedicament {
  actif
  retire
  en_rupture_nationale
}

enum StatutPharmacie {
  active
  suspendue
  fermee
}

enum TypeConsultation {
  presentiel
  teleconsultation
  domicile
}

enum StatutConsultation {
  planifiee
  effectuee
  annulee
  no_show
}

enum StatutOrdonnance {
  active
  partiellement_servie
  servie
  expiree
}

enum TypeLivraison {
  retrait_en_pharmacie
  livraison_domicile
}

enum StatutPaiement {
  en_attente
  paye
  rembourse
  echoue
}

enum ModePaiement {
  mobile_money
  especes
  carte_bancaire
}

enum StatutCommande {
  en_attente
  confirmee
  preparee
  en_livraison
  livree
  annulee
}

enum StatutRappel {
  actif
  pause
  termine
  abandonne
}

enum CanalNotification {
  sms
  whatsapp
  push
  email
}

enum NiveauUrgence {
  faible
  modere
  urgent
  tres_urgent
}

enum ModeSaisie {
  texte
  vocal
}

enum TypeAcces {
  lecture
  modification
  qr_code
  urgence
}

enum StatutPrise {
  en_attente
  prise
  manquee
  reportee
}

enum TypeActe {
  injection
  pansement
  prise_sang
  perfusion
  autre
}

enum StatutIntervention {
  planifiee
  en_cours
  terminee
  annulee
}

model Utilisateur {
  id_utilisateur      String           @id @default(uuid())
  nom                 String           @db.VarChar(100)
  prenom              String           @db.VarChar(100)
  email               String           @unique @db.VarChar(255)
  telephone           String           @unique @db.VarChar(20)
  mot_de_passe_hash   String           @db.VarChar(255)
  type_utilisateur     TypeUtilisateur
  date_naissance      DateTime?        @db.Date
  sexe                Sexe
  photo_profil        String?          @db.VarChar(500)
  latitude            Float?
  longitude           Float?
  langue_preferee     Langue           @default(fr)
  statut_compte       StatutCompte     @default(actif)
  date_creation       DateTime         @default(now())
  derniere_connexion  DateTime?
  email_verifie       DateTime?

  patient              Patient?
  professionnel        ProfessionnelSante?
  pharmacies           Pharmacie[]      @relation("PharmacienResponsable")
  tuteurPatients       Patient[]        @relation("TuteurPatient")
  accesCarnets         AccesCarnet[]    @relation("Accedant")

  @@map("utilisateur")
}

model Patient {
  id_patient               String            @id @default(uuid())
  id_utilisateur           String            @unique
  numero_carnet            String            @unique @db.VarChar(20)
  groupe_sanguin           GroupeSanguin?
  poids_kg                 Decimal?          @db.Decimal(5, 2)
  taille_cm                Int?
  allergies_connues        String?           @db.Text
  antecedents_medicaux     String?           @db.Text
  maladies_chroniques      Json?
  id_tuteur                String?
  consentement_donnees     Boolean           @default(false)
  date_enregistrement      DateTime          @default(now())

  utilisateur              Utilisateur       @relation(fields: [id_utilisateur], references: [id_utilisateur])
  tuteur                   Utilisateur?      @relation("TuteurPatient", fields: [id_tuteur], references: [id_utilisateur])
  carnet                   CarnetSante?
  consultations            Consultation[]
  ordonnances              Ordonnance[]
  commandes                Commande[]
  rappels                  RappelTraitement[]
  triages                  TriageIa[]
  interventions            InterventionDomicile[]

  @@map("patient")
}

model ProfessionnelSante {
  id_professionnel         String             @id @default(uuid())
  id_utilisateur           String             @unique
  numero_ordre             String             @unique @db.VarChar(50)
  specialite               String             @db.VarChar(100)
  sous_specialite           String?            @db.VarChar(100)
  structure_exercice       String             @db.VarChar(200)
  latitude_cabinet         Float?
  longitude_cabinet        Float?
  adresse_cabinet          String?            @db.Text
  tarif_consultation       Decimal?           @db.Decimal(10, 2)
  disponible_domicile      Boolean            @default(false)
  note_moyenne             Decimal            @default(0) @db.Decimal(3, 2)
  statut_verification      StatutVerification @default(en_attente)
  date_inscription         DateTime           @default(now())

  utilisateur              Utilisateur        @relation(fields: [id_utilisateur], references: [id_utilisateur])
  consultations            Consultation[]
  ordonnances              Ordonnance[]
  interventions            InterventionDomicile[]

  @@map("professionnel_sante")
}

model CarnetSante {
  id_carnet                String   @id @default(uuid())
  id_patient               String   @unique
  qr_code_token            String   @unique @db.VarChar(500)
  vaccinations             Json?
  date_creation            DateTime @default(now())
  derniere_mise_a_jour     DateTime @updatedAt
  acces_actif              Boolean  @default(true)

  patient                  Patient           @relation(fields: [id_patient], references: [id_patient])
  consultations            Consultation[]
  acces                    AccesCarnet[]

  @@map("carnet_sante")
}

model Consultation {
  id_consultation          String              @id @default(uuid())
  id_patient               String
  id_professionnel         String
  id_carnet                String
  date_consultation         DateTime
  motif                    String              @db.Text
  diagnostic               String?             @db.Text
  codes_cim10              String[]
  observations             String?             @db.Text
  type_consultation         TypeConsultation
  cout_fcfa                Decimal?            @db.Decimal(10, 2)
  statut                   StatutConsultation  @default(planifiee)
  pj_documents             Json?

  patient                  Patient            @relation(fields: [id_patient], references: [id_patient])
  professionnel            ProfessionnelSante  @relation(fields: [id_professionnel], references: [id_professionnel])
  carnet                   CarnetSante        @relation(fields: [id_carnet], references: [id_carnet])
  ordonnances              Ordonnance[]

  @@map("consultation")
}

model Ordonnance {
  id_ordonnance            String            @id @default(uuid())
  id_consultation          String
  id_professionnel         String
  id_patient               String
  date_emission            DateTime          @default(now())
  date_expiration          DateTime          @db.Date
  signature_numerique      String            @db.Text
  statut                   StatutOrdonnance  @default(active)
  notes_pharmacien         String?           @db.Text

  consultation             Consultation      @relation(fields: [id_consultation], references: [id_consultation])
  professionnel            ProfessionnelSante @relation(fields: [id_professionnel], references: [id_professionnel])
  patient                  Patient           @relation(fields: [id_patient], references: [id_patient])
  lignes                   LigneOrdonnance[]
  commandes                Commande[]
  rappels                  RappelTraitement[]

  @@map("ordonnance")
}

model Medicament {
  id_medicament            String                @id @default(uuid())
  nom_commercial           String                @db.VarChar(200)
  dci                      String                @db.VarChar(200)
  forme_galenique          FormeGalenique
  dosage                   String                @db.VarChar(100)
  categorie                CategorieMedicament
  est_generique            Boolean               @default(false)
  id_reference             String?
  necessite_ordonnance     Boolean               @default(true)
  prix_indicatif_fcfa      Decimal?             @db.Decimal(10, 2)
  image_url                String?               @db.VarChar(500)
  statut                   StatutMedicament      @default(actif)

  reference                Medicament?           @relation("MedicamentReference", fields: [id_reference], references: [id_medicament])
  generiques               Medicament[]          @relation("MedicamentReference")
  lignesOrdonnance          LigneOrdonnance[]
  stocks                   StockPharmacie[]
  rappels                  RappelTraitement[]

  @@map("medicament")
}

model Pharmacie {
  id_pharmacie              String             @id @default(uuid())
  id_responsable            String
  nom_pharmacie             String             @db.VarChar(200)
  numero_autorisation       String             @unique @db.VarChar(100)
  adresse                  String             @db.Text
  latitude                 Float
  longitude                 Float
  telephone                String             @db.VarChar(20)
  horaires_ouverture        Json?
  livraison_disponible      Boolean            @default(false)
  rayon_livraison_km        Decimal?           @db.Decimal(5, 2)
  note_moyenne              Decimal            @default(0) @db.Decimal(3, 2)
  statut                    StatutPharmacie    @default(active)

  responsable               Utilisateur        @relation("PharmacienResponsable", fields: [id_responsable], references: [id_utilisateur])
  stocks                    StockPharmacie[]
  commandes                 Commande[]

  @@map("pharmacie")
}

model Commande {
  id_commande               String             @id @default(uuid())
  id_patient                String
  id_pharmacie              String
  id_ordonnance             String?
  photo_ordonnance_url      String?            @db.VarChar(500)
  type_livraison            TypeLivraison
  adresse_livraison         String?            @db.Text
  latitude_livraison         Float?
  longitude_livraison       Float?
  montant_total_fcfa        Decimal            @db.Decimal(10, 2)
  statut_paiement            StatutPaiement     @default(en_attente)
  mode_paiement              ModePaiement?
  statut_commande            StatutCommande     @default(en_attente)
  date_commande              DateTime           @default(now())
  date_livraison_prevue      DateTime?
  date_livraison_effective   DateTime?

  patient                    Patient           @relation(fields: [id_patient], references: [id_patient])
  pharmacie                  Pharmacie         @relation(fields: [id_pharmacie], references: [id_pharmacie])
  ordonnance                 Ordonnance?       @relation(fields: [id_ordonnance], references: [id_ordonnance])
  lignes                     LigneCommande[]

  @@map("commande")
}

model RappelTraitement {
  id_rappel                 String              @id @default(uuid())
  id_patient                String
  id_ordonnance             String
  id_medicament             String
  frequence                 Json
  heure_prise               String[]
  date_debut                DateTime           @db.Date
  date_fin                  DateTime           @db.Date
  canal_notification         CanalNotification  @default(sms)
  alerte_tuteur_active      Boolean            @default(false)
  statut                     StatutRappel       @default(actif)

  patient                    Patient           @relation(fields: [id_patient], references: [id_patient])
  ordonnance                 Ordonnance        @relation(fields: [id_ordonnance], references: [id_ordonnance])
  medicament                 Medicament        @relation(fields: [id_medicament], references: [id_medicament])
  prises                     PriseMedicament[]

  @@map("rappel_traitement")
}

model TriageIa {
  id_triage                 String             @id @default(uuid())
  id_patient               String
  date_session             DateTime           @default(now())
  symptomes_declares        Json
  resultats_analyse         Json
  recommandation            String             @db.Text
  niveau_urgence            NiveauUrgence
  specialite_recommandee    String?            @db.VarChar(100)
  langue_session            Langue             @default(fr)
  mode_saisie               ModeSaisie         @default(texte)
  suivi_pris                Boolean            @default(false)

  patient                    Patient           @relation(fields: [id_patient], references: [id_patient])

  @@map("triage_ia")
}

model InterventionDomicile {
  id_intervention           String              @id @default(uuid())
  id_patient                String
  id_infirmier              String
  type_acte                 TypeActe
  date_planifiee            DateTime
  date_effective            DateTime?
  adresse_intervention       String             @db.Text
  latitude_intervention      Float?
  longitude_intervention     Float?
  cout_fcfa                  Decimal            @db.Decimal(10, 2)
  compte_rendu               String?            @db.Text
  statut                     StatutIntervention  @default(planifiee)
  note_patient               Int?

  patient                    Patient            @relation(fields: [id_patient], references: [id_patient])
  infirmier                  ProfessionnelSante @relation(fields: [id_infirmier], references: [id_professionnel])

  @@map("intervention_domicile")
}

model LigneOrdonnance {
  id_ligne                  String   @id @default(uuid())
  id_ordonnance             String
  id_medicament             String
  quantite                  Int
  duree_traitement_jours   Int
  posologie                 String   @db.VarChar(300)
  servi                     Boolean  @default(false)

  ordonnance                Ordonnance @relation(fields: [id_ordonnance], references: [id_ordonnance])
  medicament                Medicament @relation(fields: [id_medicament], references: [id_medicament])

  @@map("ligne_ordonnance")
}

model StockPharmacie {
  id_stock                  String   @id @default(uuid())
  id_pharmacie              String
  id_medicament             String
  quantite_disponible       Int      @default(0)
  prix_vente_fcfa           Decimal  @db.Decimal(10, 2)
  date_peremption           DateTime? @db.Date
  seuil_alerte              Int      @default(10)
  derniere_maj              DateTime @updatedAt

  pharmacie                 Pharmacie   @relation(fields: [id_pharmacie], references: [id_pharmacie])
  medicament                Medicament @relation(fields: [id_medicament], references: [id_medicament])
  lignesCommande             LigneCommande[]

  @@map("stock_pharmacie")
}

model LigneCommande {
  id_ligne_cmd              String   @id @default(uuid())
  id_commande               String
  id_stock                  String
  quantite_commandee        Int
  prix_unitaire_fcfa       Decimal  @db.Decimal(10, 2)
  sous_total_fcfa           Decimal  @db.Decimal(10, 2)

  commande                  Commande      @relation(fields: [id_commande], references: [id_commande])
  stock                      StockPharmacie @relation(fields: [id_stock], references: [id_stock])

  @@map("ligne_commande")
}

model PriseMedicament {
  id_prise                  String        @id @default(uuid())
  id_rappel                 String
  date_heure_prevue         DateTime
  date_heure_reelle         DateTime?
  statut_prise              StatutPrise   @default(en_attente)
  commentaire                String?       @db.Text

  rappel                    RappelTraitement @relation(fields: [id_rappel], references: [id_rappel])

  @@map("prise_medicament")
}

model AccesCarnet {
  id_acces                  String      @id @default(uuid())
  id_carnet                 String
  id_accedant               String
  type_acces                TypeAcces
  date_acces                DateTime    @default(now())
  adresse_ip                String?
  autorise_par_patient      Boolean     @default(true)

  carnet                    CarnetSante @relation(fields: [id_carnet], references: [id_carnet])
  accedant                  Utilisateur @relation("Accedant", fields: [id_accedant], references: [id_utilisateur])

  @@map("acces_carnet")
}
